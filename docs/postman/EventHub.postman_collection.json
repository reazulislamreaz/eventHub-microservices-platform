{
  "info": {
    "_postman_id": "eventhub-api-collection",
    "name": "EventHub API",
    "description": "EventHub microservices platform — REST & GraphQL gateway.\n\n1. Import environment `EventHub Local`\n2. Run **Auth → Login (Admin)** to set `token`\n3. Run other requests",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost:8080" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"alice@example.com\",\n  \"name\": \"Alice\",\n  \"password\": \"SecurePass123\"\n}"
            },
            "url": "{{base_url}}/api/v1/auth/register"
          }
        },
        {
          "name": "Login (Admin)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.token) {",
                  "  pm.environment.set('token', json.token);",
                  "  pm.environment.set('user_id', json.user.id);",
                  "  console.log('Token saved');",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{admin_email}}\",\n  \"password\": \"{{admin_password}}\"\n}"
            },
            "url": "{{base_url}}/api/v1/auth/login"
          }
        },
        {
          "name": "Login (User)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.token) {",
                  "  pm.environment.set('token', json.token);",
                  "  pm.environment.set('user_id', json.user.id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"alice@example.com\",\n  \"password\": \"SecurePass123\"\n}"
            },
            "url": "{{base_url}}/api/v1/auth/login"
          }
        }
      ]
    },
    {
      "name": "Users",
      "item": [
        {
          "name": "List Users",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/v1/users"
          }
        },
        {
          "name": "Get User",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/v1/users/{{user_id}}"
          }
        }
      ]
    },
    {
      "name": "Events",
      "item": [
        {
          "name": "List Events",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const events = pm.response.json();",
                  "if (Array.isArray(events) && events.length > 0) {",
                  "  pm.environment.set('event_id', events[0].id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/v1/events"
          }
        },
        {
          "name": "Create Event (Admin)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Go Conference 2026\",\n  \"description\": \"Annual Go community meetup\",\n  \"location\": \"Dhaka, Bangladesh\",\n  \"startTime\": \"2026-06-15T09:00:00Z\",\n  \"endTime\": \"2026-06-15T18:00:00Z\",\n  \"capacity\": 100\n}"
            },
            "url": "{{base_url}}/api/v1/events"
          }
        }
      ]
    },
    {
      "name": "Tickets",
      "item": [
        {
          "name": "Book Ticket",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"eventId\": \"{{event_id}}\"\n}"
            },
            "url": "{{base_url}}/api/v1/tickets"
          }
        },
        {
          "name": "Get User Tickets",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{base_url}}/api/v1/users/{{user_id}}/tickets"
          }
        }
      ]
    },
    {
      "name": "Health",
      "item": [
        {
          "name": "Health",
          "request": { "method": "GET", "url": "{{base_url}}/health" }
        },
        {
          "name": "Ready",
          "request": { "method": "GET", "url": "{{base_url}}/ready" }
        }
      ]
    },
    {
      "name": "GraphQL",
      "item": [
        {
          "name": "Login (GraphQL)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "const token = json.data?.login?.token;",
                  "if (token) pm.environment.set('token', token);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"query\": \"mutation($input: LoginInput!) { login(input: $input) { token user { id role } } }\",\n  \"variables\": {\n    \"input\": {\n      \"email\": \"{{admin_email}}\",\n      \"password\": \"{{admin_password}}\"\n    }\n  }\n}"
            },
            "url": "{{base_url}}/query"
          }
        },
        {
          "name": "Get Events (GraphQL)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"query\": \"{ getEvents { id title location availableSeats } }\"\n}"
            },
            "url": "{{base_url}}/query"
          }
        },
        {
          "name": "Book Ticket (GraphQL)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"query\": \"mutation($eventId: ID!) { bookTicket(eventId: $eventId) { id ticketCode status } }\",\n  \"variables\": { \"eventId\": \"{{event_id}}\" }\n}"
            },
            "url": "{{base_url}}/query"
          }
        }
      ]
    },
    {
      "name": "Documentation",
      "item": [
        {
          "name": "API Docs Index",
          "request": { "method": "GET", "url": "{{base_url}}/api/v1/docs" }
        },
        {
          "name": "GraphQL Schema",
          "request": { "method": "GET", "url": "{{base_url}}/api/v1/graphql/schema" }
        },
        {
          "name": "OpenAPI JSON",
          "request": { "method": "GET", "url": "{{base_url}}/swagger/doc.json" }
        }
      ]
    }
  ]
}
