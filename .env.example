# Gateway (HTTP_PORT is inside the container; GATEWAY_PORT is the host mapping in docker-compose)
HTTP_PORT=8080
GATEWAY_PORT=8082
# Leave empty so Swagger uses the same host/port as your browser (avoids CORS)
SWAGGER_HOST=
JWT_SECRET=eventhub-dev-secret-change-in-production
USER_SERVICE_ADDR=localhost:50051
EVENT_SERVICE_ADDR=localhost:50052
TICKET_SERVICE_ADDR=localhost:50053

# User Service
GRPC_PORT=50051
DB_HOST=localhost
DB_PORT=5432
DB_USER=eventhub
DB_PASSWORD=eventhub_secret
DB_NAME=user_db
DB_SSLMODE=disable

# Event Service
# GRPC_PORT=50052
# DB_HOST=localhost
# DB_PORT=5433
# DB_NAME=event_db

# Ticket Service
# GRPC_PORT=50053
# EVENT_SERVICE_ADDR=localhost:50052
# DB_HOST=localhost
# DB_PORT=5434
# DB_NAME=ticket_db
